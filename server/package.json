{
  "name": "popcorn-cinema-server",
  "version": "1.0.0",
  "description": "Backend server for Popcorn Cinema",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "testdb": "ts-node test-db.ts",
    "seed": "ts-node seed.ts",
    "db:generate": "ts-node seed.ts",
    "db:reset": "ts-node seed.ts",
    "dev": "nodemon --watch . --ext ts,d.ts --exec ts-node --files --project tsconfig.json app.ts",
    "start": "node dist/app.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "moment": "^2.30.1",
    "mongoose": "^9.3.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  }
}
