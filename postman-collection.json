              "raw": "{\n  \"showtimeId\": \"{{showtimeId}}\",\n  \"seats\": [\"A1\", \"A2\"],\n  \"snacks\": [\n    { \"snackId\": \"{{snackId}}\", \"qty\": 2 }\n  ],\n  \"promotionCode\": \"SUMMER20\",\n  \"ticketTotal\": 180000,\n  \"snackTotal\": 60000,\n  \"finalTotal\": 192000,\n  \"seatHoldId\": \"{{seatHoldId}}\"\n}",
